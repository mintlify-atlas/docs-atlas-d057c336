  "keyFeatures": [
    "NetworkBehaviour base class for multiplayer game objects",
    "SyncVars for automatic state synchronization",
    "Commands ([Command]) for client-to-server RPCs",
    "ClientRpc / TargetRpc for server-to-client RPCs",
    "Multiple transports: KCP, Telepathy, WebSockets, Steam, and more",
    "Interest Management (Spatial Hashing, Distance Checker)",
    "Snapshot Interpolation for smooth movement",
    "Lag Compensation with server-side rollback",
    "NetworkManager for connection lifecycle management",
    "IL post-processing for zero-overhead remote calls",
    "Allocation-free networking with no GC pressure",
    "Built-in authentication system",
    "Edgegap cloud hosting integration"
  ],
